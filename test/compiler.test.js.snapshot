exports[`compiler snapshot 1`] = `
".b-yellow {\\n  border-color: var(--su-yellow);\\n}\\n\\n.b-orange-800 {\\n  border-color: color-mix(in oklch, var(--su-orange), #000 60%);\\n}\\n\\n.b-red\\\\/50 {\\n  border-color: oklch(from var(--su-red) l c h / 0.5);\\n}\\n\\n.b-pink-200\\\\/30 {\\n  border-color: oklch(from color-mix(in oklch, var(--su-pink), #fff 60%) l c h / 0.3);\\n}\\n\\n.b-purple-200\\\\/60 {\\n  border-color: oklch(from color-mix(in oklch, var(--su-purple), #fff 60%) l c h / 0.6);\\n}\\n\\n.\\\\!b-blue-133\\\\/12 {\\n  border-color: oklch(from color-mix(in oklch, var(--su-blue), #fff 73.4%) l c h / 0.12) !important;\\n}\\n\\n.\\\\!d-flex {\\n  display: flex !important;\\n}\\n\\n.d-hidden {\\n  display: none;\\n}\\n\\n.\\\\!d-none {\\n  display: none !important;\\n}\\n\\n.d-grid {\\n  display: grid;\\n}\\n\\n.flex-y {\\n  display: flex;\\n  flex-direction: column;\\n}\\n\\n.flex-y {\\n  display: flex;\\n  flex-direction: column;\\n}\\n\\n.fd-row {\\n  flex-direction: row;\\n}\\n\\n.\\\\!flex-row {\\n  display: flex !important;\\n  flex-direction: row !important;\\n}\\n\\n.fw-wrap {\\n  flex-wrap: wrap;\\n}\\n\\n.m-2px {\\n  margin: 2px;\\n}\\n\\n.m-4\\\\.2px {\\n  margin: 4.2px;\\n}\\n\\n.m-3\\\\/2px {\\n  margin: 1.5px;\\n}\\n\\n.m-0 {\\n  margin: 0;\\n}\\n\\n.\\\\!m-0 {\\n  margin: 0 !important;\\n}\\n\\n.m-1 {\\n  margin: 0.25rem;\\n}\\n\\n.m-2 {\\n  margin: 0.5rem !important;\\n}\\n\\n.\\\\-m-4 {\\n  margin: -1rem !important;\\n}\\n\\n.m-2\\\\.5 {\\n  margin: 0.625rem;\\n}\\n\\n.m-12\\\\/3 {\\n  margin: 1rem;\\n}\\n\\n.p-4px {\\n  padding: 4px;\\n}\\n\\n.p-3\\\\.2px {\\n  padding: 3.2px;\\n}\\n\\n.p-3\\\\/2px {\\n  padding: 1.5px;\\n}\\n\\n.p-2 {\\n  padding: 0.5rem !important;\\n}\\n\\n.p-0 {\\n  padding: 0;\\n}\\n\\n.\\\\!p-0 {\\n  padding: 0 !important;\\n}\\n\\n.p-1 {\\n  padding: 0.25rem;\\n}\\n\\n.py-2\\\\.5 {\\n  padding-block: 0.625rem !important;\\n}\\n\\n.p-2\\\\/3 {\\n  padding: 0.167rem;\\n}\\n\\n.ps-0 {\\n  padding-inline-start: 0;\\n}\\n\\n.h1 {\\n  lineHeight: var(--su-lh-title);\\n  color: var(--su-text-title);\\n  fontSize: var(--su-fs-h1);\\n  letterSpacing: var(--su-ls-h1);\\n  fontWeight: var(--su-fw-h1);\\n}\\n\\n.h2 {\\n  lineHeight: var(--su-lh-title);\\n  color: var(--su-text-title);\\n  fontSize: var(--su-fs-h2);\\n  letterSpacing: var(--su-ls-h2);\\n  fontWeight: var(--su-fw-h2);\\n}\\n\\n.h3 {\\n  lineHeight: var(--su-lh-title);\\n  color: var(--su-text-title);\\n  fontSize: var(--su-fs-h3);\\n  letterSpacing: var(--su-ls-h3);\\n  fontWeight: var(--su-fw-h3);\\n}\\n\\n.\\\\!h4 {\\n  lineHeight: var(--su-lh-title) !important;\\n  color: var(--su-text-title) !important;\\n  fontSize: var(--su-fs-h4) !important;\\n  letterSpacing: var(--su-ls-h4) !important;\\n  fontWeight: var(--su-fw-h4) !important;\\n}\\n\\n:where([data-color-scheme=\\"dark\\"] *) {\\n  @media (orientation: landscape) {\\n    &.dark\\\\:landscape\\\\:b-cyan-1000\\\\/1 {\\n      border-color: oklch(from color-mix(in oklch, var(--su-cyan), #000 100%) l c h / 0.01);\\n    }\\n  }\\n}\\n\\n:where([data-color-scheme=\\"dark\\"] *) {\\n  @media (width >= 40rem) {\\n    &.dark\\\\:sm\\\\:d-block {\\n      display: block;\\n    }\\n  }\\n}\\n\\n:where([data-color-scheme=\\"dark\\"] *) {\\n  @media (width >= 48rem) {\\n      &.dark\\\\:md\\\\:hover\\\\:m-2\\\\.5em:hover {\\n        margin: 2.5em;\\n      }\\n      \\n      &.dark\\\\:md\\\\:hover\\\\:\\\\!m-auto:hover {\\n        margin: auto !important;\\n      }\\n      \\n      &.dark\\\\:md\\\\:hover\\\\:m-8:hover {\\n        margin: 2rem !important;\\n      }\\n      \\n      &.dark\\\\:md\\\\:hover\\\\:p-4vw:hover {\\n        padding: 4vw;\\n      }\\n      \\n      &.dark\\\\:md\\\\:hover\\\\:\\\\!px-0:hover {\\n        padding-inline: 0 !important;\\n      }\\n      \\n      &.dark\\\\:md\\\\:hover\\\\:p-2:hover {\\n        padding: 0.5rem !important;\\n      }\\n  }\\n}\\n\\n:where([data-color-scheme=\\"dark\\"] *) {\\n  @media (orientation: portrait) {\\n      &.dark\\\\:portrait\\\\:hover\\\\:\\\\!h6:hover {\\n        lineHeight: var(--su-lh-title) !important;\\n        color: var(--su-text-title) !important;\\n        fontSize: var(--su-fs-h6) !important;\\n        letterSpacing: var(--su-ls-h6) !important;\\n        fontWeight: var(--su-fw-h6) !important;\\n      }\\n  }\\n}\\n\\n  .active\\\\:fw-nowrap:active {\\n    flex-wrap: nowrap;\\n  }\\n\\n  .hover\\\\:m-3rem:hover {\\n    margin: 3rem;\\n  }\\n  \\n  .hover\\\\:m-auto:hover {\\n    margin: auto;\\n  }\\n  \\n  .hover\\\\:h5:hover {\\n    lineHeight: var(--su-lh-title);\\n    color: var(--su-text-title);\\n    fontSize: var(--su-fs-h5);\\n    letterSpacing: var(--su-ls-h5);\\n    fontWeight: var(--su-fw-h5);\\n  }\\n\\n@media (width >= 48rem) {\\n  .md\\\\:m-auto {\\n    margin: auto;\\n  }\\n}\\n\\n"
